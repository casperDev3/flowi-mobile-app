{
  "expo": {
    "name": "Flowi",
    "slug": "f-tracking-app",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/logo_app.png",
    "scheme": "ftrackingapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.casper3.f-tracking-app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#163A5F",
        "foregroundImage": "./assets/logo_app.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.casper3.ftrackingapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo_app.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo_app.png",
          "color": "#7C3AED",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo_app.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#163A5F",
          "dark": {
            "backgroundColor": "#163A5F"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
